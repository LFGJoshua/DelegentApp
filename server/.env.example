# Copy this to server/.env and fill in your values. Never commit the real .env.

# ---- Supabase Postgres ----
# Supabase dashboard → Project Settings → Database → Connection string.
# Use the POOLER string (Transaction mode, host ...pooler.supabase.com:6543) —
# the direct db.<ref>.supabase.co host is IPv6-only and usually unreachable.
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ---- Supabase Storage (screenshot images, free tier, no card) ----
# SUPABASE_URL: Project Settings → API → Project URL (https://<ref>.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY: Project Settings → API → service_role secret (KEEP SECRET)
# Create a PRIVATE Storage bucket and put its name in SUPABASE_BUCKET.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=screenshots

# ---- Server ----
PORT=4000
# Set to 1 when served over HTTPS (production) so the session cookie gets Secure.
COOKIE_SECURE=0
