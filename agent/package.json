{
  "name": "delegent-agent",
  "version": "0.1.2",
  "description": "Delegent monitoring agent — captures the screen on an interval and uploads to the backend.",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "start": "node scripts/launch.cjs",
    "dist": "electron-builder --win --publish never",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "node-global-key-listener": "^0.3.0"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "io.delegent.agent",
    "productName": "Delegent",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "electron/keyhook.ps1"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "Delegent-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "Delegent-mac-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "identity": null
    },
    "publish": [
      { "provider": "github", "owner": "LFGJoshua", "repo": "DelegentApp" }
    ]
  }
}
